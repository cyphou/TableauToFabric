[run]
source = tableau_export/,fabric_import/
omit =
    tests/*
    */__pycache__/*
    */deploy/*
    fabric_import/wizard.py
    fabric_import/telemetry_dashboard.py

[report]
show_missing = True
precision = 1
fail_under = 80
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__
    raise NotImplementedError
    pass
    except ImportError
    def main
    input\(

[html]
directory = htmlcov
title = Tableau-to-PowerBI Coverage Report
