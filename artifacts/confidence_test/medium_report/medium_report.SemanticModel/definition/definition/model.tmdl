model Model
	culture: fr-FR
	defaultPowerBIDataSourceVersion: powerBI_V3
	defaultMode: directLake
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Customers","Year Selector"]

ref table Orders
ref table Customers
ref table 'Year Selector'

ref expression DatabaseQuery

ref perspective 'Full Model'

ref culture 'fr-FR'

