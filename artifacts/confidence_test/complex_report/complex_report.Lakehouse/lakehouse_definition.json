      "source_type": "Custom SQL",
      "custom_sql": "SELECT\n              YEAR(OrderDate)  AS OrderYear,\n              MONTH(OrderDate) AS OrderMonth,\n              Category,\n              SUM(Revenue)     AS TotalRevenue,\n              SUM(Cost)        AS TotalCost,\n              COUNT(*)         AS OrderCount\n          FROM Orders\n          GROUP BY YEAR(OrderDate), MONTH(OrderDate), Category",
