# ============================================================================
# Tableau to Microsoft Fabric Migration — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# The migration tool uses these for Fabric deployment only (optional).
# Core migration (extraction + generation) works without any env vars.
# ============================================================================

# ── Required for Fabric Deployment ──────────────────────────────────────────

# Target Microsoft Fabric workspace ID (GUID)
FABRIC_WORKSPACE_ID=

# Azure AD tenant ID for authentication
FABRIC_TENANT_ID=

# Service Principal credentials (App Registration)
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=

# ── Optional Settings ───────────────────────────────────────────────────────

# Fabric REST API base URL (default: https://api.fabric.microsoft.com/v1)
FABRIC_API_BASE_URL=https://api.fabric.microsoft.com/v1

# Use Azure Managed Identity instead of Service Principal (true/false)
USE_MANAGED_IDENTITY=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Log format: text or json (default: text)
LOG_FORMAT=text

# HTTP timeout for deployment requests in seconds (default: 300)
DEPLOYMENT_TIMEOUT=300

# Number of retry attempts for failed API calls (default: 3)
RETRY_ATTEMPTS=3

# Delay between retries in seconds (default: 5)
RETRY_DELAY=5
